<?xml version="1.0" encoding="utf-8"?>
<!-- 보관함(스크랩) 화면의 세로형 아이템 레이아웃 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 사건 썸네일 이미지 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_scrap_thumbnail"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            android:src="@drawable/ic_launcher_background" />

        <!-- 연도 및 제목 -->
        <TextView
            android:id="@+id/tv_scrap_year_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="24dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="1987년: 블랙 먼데이"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_scrap_thumbnail"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 설명 (간략히) -->
        <TextView
            android:id="@+id/tv_scrap_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="뉴욕증시 폭락으로 전 세계 금융시장에 커다란 혼란이 발생했습니다."
            android:textColor="#666666"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tv_scrap_year_title"
            app:layout_constraintStart_toStartOf="@id/tv_scrap_year_title"
            app:layout_constraintTop_toBottomOf="@id/tv_scrap_year_title" />

        <!-- 스크랩 날짜 -->
        <TextView
            android:id="@+id/tv_scrap_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="스크랩 날짜: 11/15"
            android:textColor="#999999"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 삭제 버튼 (X) -->
        <ImageButton
            android:id="@+id/btn_delete_scrap"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#CCCCCC"
            android:contentDescription="@string/btn_scrap" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
